# Arb/Hedge bot — credentials

# ── Secrets ──
TELEGRAM_TOKEN=your_telegram_bot_token
CHAT_ID=your_chat_id
POLYMARKET_PRIVATE_KEY=0x...main_wallet_private_key
POLYMARKET_CHAIN_ID=137
POLYMARKET_SIGNATURE_TYPE=2
POLYMARKET_FUNDER_ADDRESS=0x...main_wallet_proxy
POLYMARKET_PRIVATE_KEY_V2=0x...arb_wallet_private_key
POLYMARKET_FUNDER_ADDRESS_V2=0x...arb_wallet_proxy

# ── Arb wallet (defaults to V2) ──
ARB_WALLET_KEY=POLYMARKET_PRIVATE_KEY_V2

# ── Toggles ──
LIVE_TRADING=false
TELEGRAM_ENABLED=true
